# ============================================================
#  LLM PROVIDER — choose how documents get read.
# ============================================================
# "ollama"    → FREE, runs locally, no API key, no billing  (DEFAULT, recommended)
# "anthropic" → Claude API (best quality, needs a paid key)
# "demo"      → no LLM at all; a built-in parser reads typed text only
LLM_PROVIDER=ollama

# --- Ollama settings (only used when LLM_PROVIDER=ollama) ---
# Install Ollama from https://ollama.com, then run:  ollama pull llava
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=llava
OLLAMA_TEXT_MODEL=llava

# --- Anthropic (only used when LLM_PROVIDER=anthropic) ------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Database (optional) ------------------------------------
# Leave blank to use an in-memory store (fine for the demo).
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=plum_opd
